{
  "name": "Monokai",
  "variables": {
    "bg": "#272822",
    "fg": "#f8f8f2",
    "accent": "#f92672",
    "title-fg": "#a6e22e",
    "border": "#49483e",
    "muted": "#75715e",
    "radius": "6"
  },
  "global": {
    "font_size": 14,
    "fg_color": "$fg",
    "bg_color": "$bg",
    "accent_color": "$accent",
    "border_color": "$border",
    "border_radius": "$radius",
    "border_width": 1,
    "padding": [8, 14, 8, 14]
  },
  "widgets": {
    "text": {
      "fg_color": "$fg"
    },
    "text:title": {
      "fg_color": "$title-fg",
      "font_weight": 700
    },
    "list": {
      "bg_color": "$bg"
    },
    "list item:selected": {
      "bg_color": "$accent",
      "fg_color": "$bg"
    }
  }
}