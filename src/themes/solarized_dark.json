{
  "name": "Solarized Dark",
  "variables": {
    "bg": "#002b36",
    "fg": "#839496",
    "accent": "#2aa198",
    "title-fg": "#268bd2",
    "border": "#073642",
    "muted": "#586e75",
    "radius": "6"
  },
  "global": {
    "font_size": 14,
    "fg_color": "$fg",
    "bg_color": "$bg",
    "accent_color": "$accent",
    "border_color": "$border",
    "border_radius": "$radius",
    "border_width": 1,
    "padding": [8, 14, 8, 14]
  },
  "widgets": {
    "text": {
      "fg_color": "$fg"
    },
    "text:title": {
      "fg_color": "$title-fg",
      "font_weight": 700
    },
    "list": {
      "bg_color": "$bg"
    },
    "list item:selected": {
      "bg_color": "$accent",
      "fg_color": "$bg"
    }
  }
}